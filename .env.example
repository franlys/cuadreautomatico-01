# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Destinatarios de Notificaciones (Opcional)
# Configurar los destinatarios por defecto para el botón "Enviar Reporte"
VITE_DUENO_EMAIL=dueno@empresa.com
VITE_DUENO_WHATSAPP=+521234567890

# Resend API Key (para Edge Functions)
# Nota: Estas variables se configuran en Supabase Edge Functions Secrets, no en el frontend
# Ver supabase/notificaciones-config.md para instrucciones completas
# RESEND_API_KEY=your_resend_api_key
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
